    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
